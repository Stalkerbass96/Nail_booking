# Single-host Docker deployment variables.
# Copy this file to .env.deploy before the first Ubuntu deployment.
#
# Important:
# - APP_BASE_URL must be the public address that users will open.
# - For pure IP testing, use http://<server-ip>:3000
# - After you add Nginx/HTTPS, change it to https://your-domain.com
# - If you enable LINE, APP_BASE_URL must also be reachable by LINE users.
# - LINE webhook must point to <APP_BASE_URL>/api/line/webhook

APP_PORT=3000
POSTGRES_DB=nail_booking
POSTGRES_USER=postgres
POSTGRES_PASSWORD=change-me-postgres
CRON_SECRET=change-me-cron-secret
ADMIN_AUTH_SECRET=change-me-admin-secret
ADMIN_SEED_PASSWORD=change-me-admin-password
AUTO_CANCEL_INTERVAL_MS=300000
APP_BASE_URL=http://127.0.0.1:3000
# Leave LINE_* empty if you are only testing web booking.
# Fill them when you are ready to enable LINE messaging, webhook, and self-linking.
LINE_CHANNEL_SECRET=
LINE_CHANNEL_ACCESS_TOKEN=
LINE_AUTO_REPLY_TEXT=Message received. The salon owner will reply to you shortly.
